{
  "manifest_version": 3,
  "name": "AI Quiz Assistant",
  "version": "1.0",
  "description": "Extract and assist with quiz questions",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://docs.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/forms/*"],
      "js": ["content.js"]
    }
  ]
}